// ──────────────────────────────────────────────────────────────────────────
// Friendly — Prisma schema (PostgreSQL)
//
// This DB stores: users, NextAuth accounts/sessions, follows, likes.
// Posts and drafts live in MongoDB (see src/models/*).
// ──────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── App user ──────────────────────────────────────────────────────────────
// One row per OAuth identity. Per spec, the same person logging in via
// different providers becomes a different user (different userID).
model User {
  id        String   @id @default(cuid())
  // App-level handle (e.g. "ric2k1"). 3–15 chars, letters/digits/underscore,
  // must not start with a digit. Validated in the API layer.
  userID    String   @unique
  // Display name from OAuth provider (e.g. "Chung-Yang Ric Huang").
  name      String
  email     String?
  avatarUrl String?
  bannerUrl String?
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // NextAuth relations
  accounts Account[]
  sessions Session[]

  // Social graph
  followers  Follow[] @relation("UserFollowers") // rows where this user is followed
  followings Follow[] @relation("UserFollowings") // rows where this user follows others

  // Likes given by this user
  likes Like[]

  @@index([userID])
}

// ── NextAuth.js (Auth.js v5) standard tables ──────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // One identity per (provider, providerAccountId) — matches our "different
  // providers => different users" rule.
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── Social graph ──────────────────────────────────────────────────────────
model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("UserFollowings", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@index([followingId])
}

// ── Likes ─────────────────────────────────────────────────────────────────
// postId points to a MongoDB Post _id (stored as string). No FK across DBs;
// orphan rows are cleaned up when a Post is hard-deleted.
model Like {
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([postId])
}
