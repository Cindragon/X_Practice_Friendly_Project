# ──────────────────────────────────────────────────────────────────────────
# Friendly — Environment variables
# Copy this file to `.env` and fill in real values.
# Never commit `.env` to git.
# ──────────────────────────────────────────────────────────────────────────

# ── Databases ─────────────────────────────────────────────────────────────
# PostgreSQL — auth, follow, like (relational integrity)
# NOTE: docker-compose maps host 5433 -> container 5432 to avoid clashing
# with any local Postgres install already on 5432.
DATABASE_URL="postgresql://friendly:friendly@localhost:5433/friendly?schema=public"

# MongoDB — posts, drafts (flexible content / recursive comments)
MONGODB_URI="mongodb://friendly:friendly@localhost:27017/friendly?authSource=admin"

# ── NextAuth.js (Auth.js v5) ──────────────────────────────────────────────
# Generate with: `openssl rand -base64 32`
AUTH_SECRET=""
# Local dev URL (set automatically on Vercel)
AUTH_URL="http://localhost:3000"
# Allow linking accounts that share the same email across providers (we keep them separate per spec)
AUTH_TRUST_HOST="true"

# ── OAuth Providers ───────────────────────────────────────────────────────
# Google: https://console.cloud.google.com/apis/credentials
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# GitHub: https://github.com/settings/developers
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Facebook: https://developers.facebook.com/apps/
AUTH_FACEBOOK_ID=""
AUTH_FACEBOOK_SECRET=""

# ── Pusher Channels ───────────────────────────────────────────────────────
# https://dashboard.pusher.com/
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER="ap3"

# Public (exposed to browser)
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="ap3"
